% Apply settings to presentation mode
\mode<presentation>

\usetheme{moloch}

\setbeamertemplate{frametitle continuation}{}
\setbeamerfont{footline}{size=\addfontfeature{Numbers=Monospaced}}

%%%%%%%%%%%%%%%%%%
% Color Settings %
%%%%%%%%%%%%%%%%%%

\definecolor{TUCgreen}{RGB}{0,140,79}
\definecolor{TUCgrey1}{RGB}{128,128,128} % mid grey
\definecolor{TUCgrey2}{RGB}{230,230,230} % light grey
\definecolor{TUCred}{RGB}{140,28,0}

\molochcolors{
  light/normal text bg=white,
  light/frametitle fg=white,
  light/frametitle bg=TUCgreen,
  light/progressbar fg=TUCgreen,
  light/title separator=TUCgreen,
}

%%%%%%%%%%%%%%%%%
% Font Settings %
%%%%%%%%%%%%%%%%%

% Use document fonts without beamer defaults
\usefonttheme{professionalfonts}
% Inherit list font for subitems
\setbeamerfont*{itemize/enumerate subbody}{parent=itemize/enumerate body}
% Inherit list font for subsubitems
\setbeamerfont*{itemize/enumerate subsubbody}{parent=itemize/enumerate body}

\mode<all>
